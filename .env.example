# Скопируй в .env и заполни

# Токен Telegram-бота от @BotFather
BOT_TOKEN=

# LLM-провайдер. Клиент OpenAI-совместимый, поэтому подходят Groq / OpenAI / Gemini(OpenAI-compat).
# Groq (бесплатно, быстро):
LLM_PROVIDER=polza
LLM_API_KEY=
LLM_MODEL=google/gemini-2.5-flash-lite
LLM_MODEL_FAST=google/gemini-2.5-flash-lite
LLM_BASE_URL=https://polza.ai/api/v1

# Пример OpenAI:
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o
# LLM_MODEL_FAST=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1

# Игровые параметры
DB_PATH=detective.db
START_MOVES=12
